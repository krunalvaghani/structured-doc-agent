# OpenRouter (recommended) — Anthropic Agent SDK via OpenRouter proxy
OPENROUTER_API_KEY=sk-or-v1-your-key
ANTHROPIC_BASE_URL=https://openrouter.ai/api
ANTHROPIC_API_KEY=

# Direct Anthropic (alternative — comment out OpenRouter vars above)
# ANTHROPIC_API_KEY=sk-ant-your-key

# Optional model overrides (OpenRouter slugs when using OpenRouter)
# EXTRACTOR_MODEL=kimi-k2.6
# EXTRACTOR_SCHEMA_MODEL=deepseek-v4-pro

# Cap agent output tokens (OpenRouter credits; default 8000)
# EXTRACTOR_MAX_OUTPUT_TOKENS=8000

# OPENROUTER_PRICING_JSON='{"moonshotai/kimi-k2.6":{"input":0.95,"output":4.0}}'

# Rate limits (off by default — enable on public deploy)
# EXTRACTOR_RATE_LIMIT_ENABLED=false
# EXTRACTOR_RATE_LIMIT_PER_IP=5
# EXTRACTOR_RATE_LIMIT_PER_IP_WINDOW_SECONDS=3600
# EXTRACTOR_RATE_LIMIT_GLOBAL_DAILY=20
# LOG_LEVEL=INFO
